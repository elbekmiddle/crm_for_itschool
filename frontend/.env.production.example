# Production build uchun namuna (vite build)
#
# 1) Nusxa oling:
#    cp .env.production.example .env.production
# 2) Quyidagi qiymatlarni o‘z serveringizga moslang
# 3) Keyin: npm run build
#
# HTTPS va haqiqiy domen ishlating.

# Backend API — oxirida /api/v1
VITE_API_URL=https://api.sizning-domen.uz/api/v1

# Odatda shart emas: VITE_API_URL dan origin olinadi.
# Faqat WebSocket alohida domen/subdomen bo‘lsa:
# VITE_SOCKET_URL=https://api.sizning-domen.uz
