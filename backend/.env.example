# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=secret
DB_NAME=crm_db

# JWT Authentication
JWT_SECRET=super-secret-key-change-me
JWT_REFRESH_SECRET=another-super-secret-refresh-key
JWT_REFRESH_EXPIRES_IN=7d

# Redis Configuration (Caching & Rate Limiting)
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Server (Nest) — frontend Vite odatda 5173
PORT=5001

# production — CORS qat’iy, Swagger o‘chadi (staging uchun: ENABLE_SWAGGER=true)
NODE_ENV=development
# ENABLE_SWAGGER=true

# CORS + Socket.IO: frontend origin(lar)i — WebSocket ham shu ro‘yxatdan foydalanadi (credentials).
# LAN orqali ochsangiz: http://192.168.x.x:5173 ni ham qo‘shing.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000,https://sizning-domen.uz


# OpenAI — imtihon (JSON), matn/kod baholash, analitika xulosasi (gpt-4o-mini tavsiya etiladi)
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# Google Gemini (REST API, qo‘shimcha npm paket shart emas)
# AI_PROVIDER: openai | gemini | bo‘sh
#   bo‘sh = avvalo OpenAI kaliti bo‘lsa OpenAI, aks holda Gemini
# Faqat Gemini ishlatish: GEMINI_API_KEY=... va AI_PROVIDER=gemini
GEMINI_API_KEY=
# Model: gemini-2.0-flash yoki gemini-1.5-flash (loyihangizda qaysi ochiq bo‘lsa)
GEMINI_MODEL=gemini-2.5-flash
AI_PROVIDER=

# Cloudinary Configuration (For User Profile Avatars)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=your_api_secret_hash

# Telegram — tasdiqlash kodlari va admin xabarlari (TelegramService)
TELEGRAM_BOT_TOKEN=
# Qabul / menyu boti (Grammy polling). Ikki Nest jarayoni bir token bilan ishga tushsa 409 chiqadi.
# Faqat bitta instansiya yoki pollingni o‘chirish: TELEGRAM_RECEPTION_POLLING=false
TELEGRAM_RECEPTION_POLLING=true

# Standalone Telegram bot (npm run start:bot — backend/bot.js) inline menyu havolalari
PUBLIC_WEB_URL=http://localhost:5173
# Kurslar ro‘yxati botda PostgreSQL `courses` jadvalidan olinadi (alohida URL shart emas).
# Blog tashqi havola (ixtiyoriy):
# TELEGRAM_MENU_BLOG_URL=https://sizning-domen.uz/blog
TELEGRAM_MENU_BLOG_URL=
