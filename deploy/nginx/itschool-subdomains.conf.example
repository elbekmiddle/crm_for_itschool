# GCP Compute Engine (yoki boshqa VM) uchun nginx namunasi.
# Faylni nusxalang: sudo cp ... /etc/nginx/sites-available/itschool
# sudo ln -s /etc/nginx/sites-available/itschool /etc/nginx/sites-enabled/
# sudo nginx -t && sudo systemctl reload nginx
#
# SSL: sudo apt install certbot python3-certbot-nginx
#      sudo certbot --nginx -d api.sizning-domen.uz -d app.sizning-domen.uz -d exam.sizning-domen.uz
#
# Backend .env:
#   ALLOWED_ORIGINS=https://app.sizning-domen.uz,https://exam.sizning-domen.uz
# Frontend build (.env.production):
#   VITE_API_URL=https://api.sizning-domen.uz/api/v1
#   VITE_SOCKET_URL=https://api.sizning-domen.uz
# Exam-platform:
#   xuddi shu VITE_* (agar alohida domen bo‘lsa, ALLOWED_ORIGINS ga exam origin qo‘shing)

map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

upstream nest_backend {
    server 127.0.0.1:5001;
    keepalive 32;
}

# --- API + WebSocket (Nest bir portda) ---
server {
    listen 80;
    listen [::]:80;
    server_name api.sizning-domen.uz;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name api.sizning-domen.uz;

    # certbot ssl_certificate va ssl_certificate_key qatorlarini qo‘shadi
    # ssl_certificate /etc/letsencrypt/live/api.sizning-domen.uz/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/api.sizning-domen.uz/privkey.pem;
    # include /etc/letsencrypt/options-ssl-nginx.conf;
    # ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    client_max_body_size 25m;

    location / {
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_read_timeout 86400s;
        proxy_send_timeout 86400s;
        proxy_pass http://nest_backend;
    }
}

# --- CRM frontend (Vite dist) ---
server {
    listen 80;
    listen [::]:80;
    server_name app.sizning-domen.uz;
    location /.well-known/acme-challenge/ { root /var/www/certbot; }
    location / { return 301 https://$host$request_uri; }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name app.sizning-domen.uz;

    root /var/www/crm/dist;
    index index.html;

    gzip on;
    gzip_types text/plain text/css application/json application/javascript image/svg+xml;

    location / {
        try_files $uri $uri/ /index.html;
    }

    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff2?)$ {
        expires 7d;
        add_header Cache-Control "public, immutable";
        try_files $uri =404;
    }
}

# --- Exam platform (ixtiyoriy alohida domen) ---
server {
    listen 80;
    listen [::]:80;
    server_name exam.sizning-domen.uz;
    location /.well-known/acme-challenge/ { root /var/www/certbot; }
    location / { return 301 https://$host$request_uri; }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name exam.sizning-domen.uz;

    root /var/www/exam-platform/dist;
    index index.html;

    gzip on;
    gzip_types text/plain text/css application/json application/javascript image/svg+xml;

    location / {
        try_files $uri $uri/ /index.html;
    }

    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff2?)$ {
        expires 7d;
        add_header Cache-Control "public, immutable";
        try_files $uri =404;
    }
}
