# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=secret
DB_NAME=crm_db

# JWT Authentication
JWT_SECRET=super-secret-key-change-me
JWT_REFRESH_SECRET=another-super-secret-refresh-key
JWT_REFRESH_EXPIRES_IN=7d

# Redis Configuration (Caching & Rate Limiting)
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Server (Nest) — frontend Vite odatda 5173
PORT=5001

# CORS: frontend manzillari (vergul bilan). Productionda HTTPS domen qo‘shing.
# Frontend VITE_API_URL qaysi originga so‘rov yuborsa, shu origin ro‘yxatda bo‘lishi kerak.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000,https://sizning-domen.uz


# OpenAI — imtihon (JSON), matn/kod baholash, analitika xulosasi (gpt-4o-mini tavsiya etiladi)
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# Cloudinary Configuration (For User Profile Avatars)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=your_api_secret_hash
